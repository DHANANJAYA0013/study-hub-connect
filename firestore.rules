rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the calling user's role from the users collection
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && userRole() == 'admin';
    }

    function isTeacher() {
      return request.auth != null && userRole() == 'teacher';
    }

    function isStudent() {
      return request.auth != null && userRole() == 'student';
    }

    function isAdminOrTeacher() {
      return isAdmin() || isTeacher();
    }

    // ── Users collection ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own profile; admins can read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Only admins can create / update / delete user documents
      allow write: if isAdmin();
    }

    // ── Signup requests ───────────────────────────────────────────────────────
    match /signup_requests/{requestId} {
      // Anyone can create a signup request (unauthenticated or authenticated)
      allow create: if true;
      // Only admins can read, update, or delete requests
      allow read, update, delete: if isAdmin();
    }

    // ── Video progress ────────────────────────────────────────────────────────
    match /video_progress/{docId} {
      // Users can read and write their own progress
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      // Allow creating a new progress doc where userId matches the caller
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Completed videos ──────────────────────────────────────────────────────
    match /completed_videos/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Class passcodes ───────────────────────────────────────────────────────
    // Any authenticated user can READ (to verify passcode on class click)
    // Only admins and teachers can WRITE (set / update / remove passcodes)
    match /class_passcodes/{classId} {
      allow read: if request.auth != null;
      allow write: if isAdminOrTeacher();
    }
  }
}
